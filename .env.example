# ==========================================
# GENERAL CONFIGURATION
# ==========================================
DATABASE_URL=sqlite:///tenders.db
CHECK_INTERVAL_MINUTES=60

# ==========================================
# MAIL CONFIGURATION (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
MAIL_FROM=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_TO=recipient1@example.com,recipient2@example.com

# ==========================================
# TELEGRAM NOTIFIER CONFIGURATION
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_channel_or_chat_id

# ==========================================
# CLASSIFICATION & AI CONFIGURATION
# ==========================================
# Yapay zeka ile otomatik sektörel sınıflandırma için Gemini API Anahtarı
GEMINI_API_KEY=your_gemini_api_key_here
